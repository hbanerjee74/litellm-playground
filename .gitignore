# Python
__pycache__/
*.py[cod]
*.egg-info/

# uv / virtualenv
.venv/

# Env files (may contain provider API keys)
.env
.env.*
!.env.example

# Editors / OS
.DS_Store
.idea/
.vscode/

# Local Obot runtime state under .obot/data/ — regenerated on container start.
# Each subdir Obot creates is listed explicitly; add new ones here as they appear.
# (Credentials — bootstrap token, API key — live in .env via direnv, not here.)
.obot/data/.config/
.obot/data/.local/
.obot/data/apiserver.local.config/
.obot/data/audit/
.obot/data/cache/
.obot/data/postgresql/
