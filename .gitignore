# Python
__pycache__/
*.py[cod]
*.egg-info/

# uv / virtualenv
.venv/

# Env files (may contain provider API keys)
.env
.env.*
!.env.example

# Editors / OS
.DS_Store
.idea/
.vscode/

# Local Obot data dir (mounted into Obot container)
# Layout under .obot/data/:
#   postgresql/   embedded PG state — large, transient — ignored
#   audit/        Obot audit JSONL logs                  — ignored
#   keys/         bootstrap token, optional enc config   — contents ignored
#                 but the README.md template is committed so contributors
#                 know what files to generate locally.
.obot/data/*
!.obot/data/keys/
.obot/data/keys/*
!.obot/data/keys/README.md
