# Used by every sample that hits an OpenRouter-backed LLM
# (LiteLLM notebook, OpenHands SDK samples). Sign up at
# https://openrouter.ai and grab a key from your account settings.
OPENROUTER_API_KEY=

# Obot configuration for the MCP REPL sample
# (samples/mcp_obot_linear_repl.py). Obot is started via the docker run
# command documented in
# docs/superpowers/specs/2026-06-06-mcp-obot-linear-repl-design.md.

# OBOT_URL: where Obot is reachable from this machine. Production
# (per lock-in #3) puts Obot behind Studio's nginx — but for the
# experiment we publish 8080 directly to localhost.
OBOT_URL=http://localhost:8080

# OBOT_BOOTSTRAP_TOKEN: Obot's admin auth. Used (a) by the docker run
# command to seed Obot on first launch, (b) by the curl command that
# mints OBOT_API_KEY. After both, it remains in env for any later admin
# REST calls. Production Studio installer reads its equivalent from
# ${DATA_DIR}/keys/ per lock-in #8.
# Generate once:
#   openssl rand -hex 32
OBOT_BOOTSTRAP_TOKEN=

# OBOT_API_KEY: per-user API key minted against Obot for MCP transport.
# Format is `ok1-<userId>-<keyId>-<secret>` (see spec setup step 5).
# In local mode this belongs to the synthetic "bootstrap" user;
# in K8s production each Studio user gets their own (lock-in #10).
# Generate (after Obot is running and OBOT_BOOTSTRAP_TOKEN is in env):
#   curl -X POST $OBOT_URL/api/api-keys \
#     -H "Authorization: Bearer $OBOT_BOOTSTRAP_TOKEN" \
#     -H "Content-Type: application/json" \
#     -d '{"name":"studio-local","mcpServerIds":["*"],"canAccessSkills":false}'
OBOT_API_KEY=

# OBOT_MCP_SERVER_ID: the per-install identifier Obot assigns to your
# installed Linear MCP server. The MCP transport URL is
# {OBOT_URL}/mcp-connect/{OBOT_MCP_SERVER_ID}/mcp — per-server, NOT a
# single gateway endpoint. After installing Linear in Obot's admin UI,
# discover the ID via either:
#   docker inspect <linear-container> --format '{{.Config.Labels}}'  # look for mcp.server.id
# or:
#   curl -H "Authorization: Bearer $OBOT_BOOTSTRAP_TOKEN" $OBOT_URL/api/all-mcps/servers
# (the latter only lists servers owned by the bootstrap user; if you
# installed Linear as a different Obot user, use the docker label path).
OBOT_MCP_SERVER_ID=
